# /etc/pam.d/gdm-fingerprint - PAM configuration for GDM fingerprint with lid-check
#
# This example skips fingerprint authentication when the laptop lid is closed.
# When lid is closed, authentication will fall through to gdm-password.

#%PAM-1.0

# Skip fingerprint if lid is closed
auth    [success=1 default=ignore]    pam_exec.so quiet /usr/local/bin/check-lid

# Fingerprint authentication (sufficient = success stops processing)
auth    sufficient                     pam_fprintd.so

# Deny if fingerprint failed
auth    required                       pam_deny.so

# Standard account management
account required    pam_nologin.so
account include     system-local-login

# Session management
session include     system-local-login
