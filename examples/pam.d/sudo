# /etc/pam.d/sudo - PAM configuration for sudo with lid-check
#
# This example skips fingerprint authentication when the laptop lid is closed.
# Adjust paths and other modules according to your distribution.

#%PAM-1.0

# Skip fingerprint if lid is closed (returns 0 = success when closed)
# [success=1] skips the next line, [default=ignore] continues normally
auth    [success=1 default=ignore]    pam_exec.so quiet /usr/local/bin/check-lid

# Fingerprint authentication (skipped if lid is closed)
auth    sufficient                     pam_fprintd.so

# Fallback to password authentication
auth    required                       pam_unix.so try_first_pass nullok

# Standard account, password, and session management
account required    pam_unix.so
password required   pam_unix.so
session required    pam_unix.so
